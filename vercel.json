{
  "rewrites": [
    { "source": "/oracle", "destination": "/oracle.html" },
    { "source": "/calendar", "destination": "/calendar.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
